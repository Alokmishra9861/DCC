generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  MEMBER
  EMPLOYER
  ASSOCIATION
  BUSINESS
  B2B
  ADMIN
}

enum MembershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum MembershipType {
  INDIVIDUAL
  EMPLOYER
  ASSOCIATION
}

enum OfferType {
  DISCOUNT
  VALUE_ADDED_CERTIFICATE
  PREPAID_CERTIFICATE
}

enum CertificateStatus {
  AVAILABLE
  PURCHASED
  REDEEMED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum AdStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

// ─────────────────────────────────────────
// USER (Base for all roles)
// ─────────────────────────────────────────

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  password         String
  role             Role
  isEmailVerified  Boolean  @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiry DateTime?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  member      Member?
  employer    Employer?
  association Association?
  business    Business?
  b2bPartner  B2BPartner?

  @@map("users")
}

// ─────────────────────────────────────────
// MEMBER
// ─────────────────────────────────────────

model Member {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])

  firstName    String
  lastName     String
  phone        String?
  age          Int?
  sex          String?
  district     String?
  salaryLevel  String?
  avatarUrl    String?
  qrCode       String?  // generated QR data string

  // Links
  employerId   String?  @db.ObjectId
  employer     Employer? @relation(fields: [employerId], references: [id])
  associationId String? @db.ObjectId
  association  Association? @relation(fields: [associationId], references: [id])

  // Aggregated stats (updated on each transaction)
  totalSavings   Float @default(0)
  totalSpent     Float @default(0)

  membership     Membership?
  transactions   Transaction[]
  certPurchases  CertificatePurchase[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("members")
}

// ─────────────────────────────────────────
// EMPLOYER
// ─────────────────────────────────────────

model Employer {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])

  companyName     String
  industry        String?
  district        String?
  phone           String?
  logoUrl         String?
  isApproved      Boolean  @default(false)

  // Aggregated
  totalMembershipCost Float @default(0)
  totalSavings        Float @default(0)

  members         Member[]
  memberships     Membership[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("employers")
}

// ─────────────────────────────────────────
// ASSOCIATION
// ─────────────────────────────────────────

model Association {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])

  name            String
  type            String?   // professional, community, trade
  district        String?
  phone           String?
  logoUrl         String?
  isApproved      Boolean   @default(false)

  totalMembershipCost Float @default(0)
  totalSavings        Float @default(0)

  members         Member[]
  memberships     Membership[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("associations")
}

// ─────────────────────────────────────────
// BUSINESS PARTNER
// ─────────────────────────────────────────

model Business {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])

  name          String
  category      String?
  description   String?
  phone         String?
  email         String?
  address       String?
  district      String?
  website       String?
  logoUrl       String?
  imageUrls     String[]
  videoUrl      String?

  // Payment processor connection
  stripeAccountId  String?
  paypalEmail      String?

  isApproved    Boolean  @default(false)
  isB2B         Boolean  @default(false)  // also listed in B2B dir

  offers        Offer[]
  transactions  Transaction[]
  advertisements Advertisement[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("businesses")
}

// ─────────────────────────────────────────
// B2B PARTNER
// ─────────────────────────────────────────

model B2BPartner {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])

  companyName   String
  servicesOffered String?
  phone         String?
  email         String?
  logoUrl       String?
  website       String?
  isApproved    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("b2b_partners")
}

// ─────────────────────────────────────────
// MEMBERSHIP
// ─────────────────────────────────────────

model Membership {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String          @unique @db.ObjectId
  member          Member          @relation(fields: [memberId], references: [id])

  type            MembershipType
  status          MembershipStatus @default(PENDING)
  priceUSD        Float
  startDate       DateTime?
  expiryDate      DateTime?

  // Optional links for employer/association memberships
  employerId      String?  @db.ObjectId
  employer        Employer? @relation(fields: [employerId], references: [id])
  associationId   String?  @db.ObjectId
  association     Association? @relation(fields: [associationId], references: [id])

  // Payment
  paymentProvider PaymentProvider?
  paymentId       String?          // Stripe/PayPal payment ID
  paymentStatus   PaymentStatus    @default(PENDING)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("memberships")
}

// ─────────────────────────────────────────
// OFFER
// ─────────────────────────────────────────

model Offer {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String    @db.ObjectId
  business      Business  @relation(fields: [businessId], references: [id])

  type          OfferType
  title         String
  description   String?
  imageUrl      String?
  discountValue Float?    // percentage or fixed amount
  minSpend      Float?    // for value-added certs
  isActive      Boolean   @default(true)
  expiryDate    DateTime?

  // Stats
  views         Int @default(0)
  clicks        Int @default(0)

  certificates  Certificate[]
  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("offers")
}

// ─────────────────────────────────────────
// CERTIFICATE
// ─────────────────────────────────────────

model Certificate {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  offerId       String            @db.ObjectId
  offer         Offer             @relation(fields: [offerId], references: [id])

  faceValue     Float             // e.g. $100
  memberPrice   Float             // e.g. $90
  status        CertificateStatus @default(AVAILABLE)
  claimCode     String?           @unique
  expiryDate    DateTime?

  purchases     CertificatePurchase[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("certificates")
}

// ─────────────────────────────────────────
// CERTIFICATE PURCHASE
// ─────────────────────────────────────────

model CertificatePurchase {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  certificateId   String          @db.ObjectId
  certificate     Certificate     @relation(fields: [certificateId], references: [id])
  memberId        String          @db.ObjectId
  member          Member          @relation(fields: [memberId], references: [id])

  amountPaid      Float
  savingsAmount   Float           // faceValue - memberPrice
  paymentProvider PaymentProvider
  paymentId       String
  paymentStatus   PaymentStatus   @default(PENDING)

  redeemedAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("certificate_purchases")
}

// ─────────────────────────────────────────
// TRANSACTION (QR-based)
// ─────────────────────────────────────────

model Transaction {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String            @db.ObjectId
  member          Member            @relation(fields: [memberId], references: [id])
  businessId      String            @db.ObjectId
  business        Business          @relation(fields: [businessId], references: [id])
  offerId         String?           @db.ObjectId
  offer           Offer?            @relation(fields: [offerId], references: [id])

  saleAmount      Float
  discountAmount  Float             @default(0)
  savingsAmount   Float             @default(0)

  // Denormalized for analytics (snapshotted at time of transaction)
  memberAge       Int?
  memberSex       String?
  memberDistrict  String?
  memberSalaryLevel String?
  businessCategory  String?
  businessDistrict  String?

  status          TransactionStatus @default(COMPLETED)
  transactionDate DateTime          @default(now())

  createdAt       DateTime @default(now())

  @@map("transactions")
}

// ─────────────────────────────────────────
// TRAVEL BOOKING
// ─────────────────────────────────────────

model TravelBooking {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String  @db.ObjectId

  category        String  // hotel, flight, car, cruise, etc.
  providerRef     String  // external booking reference
  bookingData     Json    // raw data from travel API
  totalPrice      Float
  commissionAmount Float  @default(0)
  savingsAmount   Float   @default(0)

  bookedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("travel_bookings")
}

// ─────────────────────────────────────────
// ADVERTISEMENT
// ─────────────────────────────────────────

model Advertisement {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String    @db.ObjectId
  business      Business  @relation(fields: [businessId], references: [id])

  title         String
  imageUrl      String
  linkUrl       String?
  placement     String    // e.g. "header", "sidebar", "footer"
  width         Int       @default(728)
  height        Int       @default(200)
  status        AdStatus  @default(ACTIVE)
  startDate     DateTime?
  endDate       DateTime?

  impressions   Int @default(0)
  clicks        Int @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("advertisements")
}

// ─────────────────────────────────────────
// CONTACT INQUIRY
// ─────────────────────────────────────────

model ContactInquiry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  type        String?
  status      String   @default("pending")
  response    String?
  respondedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contact_inquiries")
}

// ─────────────────────────────────────────
// AUDIT LOG (Admin)
// ─────────────────────────────────────────

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}
