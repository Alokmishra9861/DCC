generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  MEMBER
  EMPLOYER
  ASSOCIATION
  BUSINESS
  B2B
  ADMIN
}

enum MembershipStatus {
  PENDING
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum MembershipType {
  INDIVIDUAL
  EMPLOYER
  ASSOCIATION
}

enum OfferType {
  DISCOUNT
  VALUE_ADDED_CERTIFICATE
  PREPAID_CERTIFICATE
}

enum CertificateStatus {
  AVAILABLE
  PURCHASED
  REDEEMED
  EXPIRED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MANUAL   // test mode / admin-assigned payments
}

enum AdStatus {
  ACTIVE
  INACTIVE
  SCHEDULED
}

// ── NEW: Employee invite/status lifecycle ─────────────────────────────────────
enum EmployeeStatus {
  INVITED    // email sent, not yet accepted
  ACTIVE     // accepted invite, membership activated
  REMOVED    // employer removed them
}

// ── NEW: Employer bulk purchase plan tiers ────────────────────────────────────
enum EmployerPlanType {
  BASIC       // e.g. up to 10 seats
  STANDARD    // up to 50 seats
  ENTERPRISE  // unlimited
}

// ─────────────────────────────────────────
// USER (Base for all roles)
// ─────────────────────────────────────────

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  password         String
  role             Role
  isEmailVerified  Boolean  @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExpiry DateTime?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  member      Member?
  employer    Employer?
  association Association?
  business    Business?
  b2bPartner  B2BPartner?

  @@map("users")
}

// ─────────────────────────────────────────
// MEMBER
// ─────────────────────────────────────────

model Member {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])

  firstName    String
  lastName     String
  phone        String?
  age          Int?
  sex          String?
  district     String?
  salaryLevel  String?
  avatarUrl    String?
  qrCode       String?

  employerId    String?  @db.ObjectId
  employer      Employer? @relation(fields: [employerId], references: [id])
  associationId String?  @db.ObjectId
  association   Association? @relation(fields: [associationId], references: [id])

  // Back-link to the Employee record that sponsored this member account
  employeeRecord Employee? @relation("EmployeeMember")

  totalSavings   Float @default(0)
  totalSpent     Float @default(0)

  membership     Membership?
  transactions   Transaction[]
  certPurchases  CertificatePurchase[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("members")
}

// ─────────────────────────────────────────
// EMPLOYER
// ─────────────────────────────────────────

model Employer {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])

  companyName     String
  industry        String?
  district        String?
  phone           String?
  logoUrl         String?

  // Approval (mirrors Business pattern — admin sets this)
  isApproved      Boolean  @default(false)
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  rejectionReason String?

  // ── NEW: Bulk membership seat tracking ───────────────────────────────────
  planType        EmployerPlanType?  // which plan was purchased
  seatsPurchased  Int      @default(0)  // total seats bought
  seatsUsed       Int      @default(0)  // seats assigned to active employees
  planStartDate   DateTime?
  planExpiryDate  DateTime?

  // Payment reference for the bulk purchase
  bulkPaymentProvider PaymentProvider?
  bulkPaymentId       String?
  bulkPaymentStatus   PaymentStatus    @default(PENDING)
  bulkPriceUSD        Float            @default(0)

  // Aggregated ROI stats (updated on each employee transaction)
  totalMembershipCost Float @default(0)
  totalSavings        Float @default(0)  // sum of all employee savings
  totalRedemptions    Int   @default(0)

  members         Member[]
  memberships     Membership[]
  employees       Employee[]   // ← NEW

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("employers")
}

// ─────────────────────────────────────────
// EMPLOYEE  ← NEW MODEL
// Represents a person invited by an employer.
// When they accept, a Member + User record is created and linked here.
// ─────────────────────────────────────────

model Employee {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId

  employerId      String         @db.ObjectId
  employer        Employer       @relation(fields: [employerId], references: [id])

  // Pre-invite fields (set by employer before User exists)
  email           String
  name            String

  status          EmployeeStatus @default(INVITED)

  // Invite token — sent in welcome email, consumed on first login/activation
  inviteToken     String?        @unique
  inviteExpiresAt DateTime?
  inviteSentAt    DateTime?
  inviteAcceptedAt DateTime?

  // Once employee accepts → their User and Member records are linked here
  userId          String?        @unique @db.ObjectId
  memberId        String?        @unique @db.ObjectId
  member          Member?        @relation("EmployeeMember", fields: [memberId], references: [id])

  // Snapshot savings for this employee (denormalized for employer dashboard speed)
  totalSavings    Float          @default(0)
  totalRedemptions Int           @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // One employer cannot invite the same email twice
  @@unique([employerId, email])
  @@map("employees")
}

// ─────────────────────────────────────────
// ASSOCIATION
// ─────────────────────────────────────────

model Association {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @unique @db.ObjectId
  user            User     @relation(fields: [userId], references: [id])

  name            String
  type            String?
  district        String?
  phone           String?
  logoUrl         String?
  isApproved      Boolean  @default(false)

  totalMembershipCost Float @default(0)
  totalSavings        Float @default(0)

  members         Member[]
  memberships     Membership[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("associations")
}

// ─────────────────────────────────────────
// BUSINESS PARTNER
// ─────────────────────────────────────────

model Business {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])

  name          String
  categoryId    String?  @db.ObjectId
  category      Category? @relation(fields: [categoryId], references: [id])
  description   String?
  phone         String?
  email         String?
  address       String?
  district      String?
  website       String?
  logoUrl       String?
  imageUrls     String[]
  videoUrl      String?

  stripeAccountId  String?
  paypalEmail      String?

  isApproved    Boolean  @default(false)
  status        String   @default("PENDING")
  isB2B         Boolean  @default(false)

  offers        Offer[]
  transactions  Transaction[]
  advertisements Advertisement[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("businesses")
}

// ─────────────────────────────────────────
// B2B PARTNER
// ─────────────────────────────────────────

model B2BPartner {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  user          User     @relation(fields: [userId], references: [id])

  companyName   String
  servicesOffered String?
  phone         String?
  email         String?
  logoUrl       String?
  website       String?
  isApproved    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("b2b_partners")
}

// ─────────────────────────────────────────
// MEMBERSHIP
// ─────────────────────────────────────────

model Membership {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String          @unique @db.ObjectId
  member          Member          @relation(fields: [memberId], references: [id])

  type            MembershipType
  status          MembershipStatus @default(PENDING)
  priceUSD        Float
  startDate       DateTime?
  expiryDate      DateTime?

  employerId      String?  @db.ObjectId
  employer        Employer? @relation(fields: [employerId], references: [id])
  associationId   String?  @db.ObjectId
  association     Association? @relation(fields: [associationId], references: [id])

  paymentProvider PaymentProvider?
  paymentId       String?
  paymentStatus   PaymentStatus    @default(PENDING)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("memberships")
}

// ─────────────────────────────────────────
// OFFER
// ─────────────────────────────────────────

model Offer {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String    @db.ObjectId
  business      Business  @relation(fields: [businessId], references: [id])

  type          OfferType
  title         String
  description   String?
  imageUrl      String?
  discountValue Float?
  minSpend      Float?
  isActive      Boolean   @default(true)
  expiryDate    DateTime?

  views         Int @default(0)
  clicks        Int @default(0)

  certificates  Certificate[]
  transactions  Transaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("offers")
}

// ─────────────────────────────────────────
// CERTIFICATE
// ─────────────────────────────────────────

model Certificate {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  offerId       String            @db.ObjectId
  offer         Offer             @relation(fields: [offerId], references: [id])

  faceValue     Float
  memberPrice   Float
  status        CertificateStatus @default(AVAILABLE)
  claimCode     String?           @unique
  expiryDate    DateTime?

  purchases     CertificatePurchase[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("certificates")
}

// ─────────────────────────────────────────
// CERTIFICATE PURCHASE
// ─────────────────────────────────────────

model CertificatePurchase {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  certificateId   String          @db.ObjectId
  certificate     Certificate     @relation(fields: [certificateId], references: [id])
  memberId        String          @db.ObjectId
  member          Member          @relation(fields: [memberId], references: [id])

  stripeSessionId String?         @unique
  paymentProvider PaymentProvider
  paymentId       String
  paymentStatus   PaymentStatus   @default(PENDING)

  type            String
  faceValue       Float
  amountPaid      Float
  savingsAmount   Float
  discountValue   Float?
  minSpend        Float?
  businessName    String
  title           String?

  uniqueCode      String?         @unique @db.String

  status          String          @default("PURCHASED")
  expiryDate      DateTime?
  purchasedAt     DateTime?
  redeemedAt      DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("certificate_purchases")
}

// ─────────────────────────────────────────
// TRANSACTION (QR-based)
// ─────────────────────────────────────────

model Transaction {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String            @db.ObjectId
  member          Member            @relation(fields: [memberId], references: [id])
  businessId      String            @db.ObjectId
  business        Business          @relation(fields: [businessId], references: [id])
  offerId         String?           @db.ObjectId
  offer           Offer?            @relation(fields: [offerId], references: [id])

  saleAmount      Float
  discountAmount  Float             @default(0)
  savingsAmount   Float             @default(0)

  memberAge       Int?
  memberSex       String?
  memberDistrict  String?
  memberSalaryLevel String?
  businessCategory  String?
  businessDistrict  String?

  status          TransactionStatus @default(COMPLETED)
  transactionDate DateTime          @default(now())

  createdAt       DateTime @default(now())

  @@map("transactions")
}

// ─────────────────────────────────────────
// TRAVEL BOOKING
// ─────────────────────────────────────────

model TravelBooking {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  memberId        String  @db.ObjectId

  category        String
  providerRef     String
  bookingData     Json
  totalPrice      Float
  commissionAmount Float  @default(0)
  savingsAmount   Float   @default(0)

  bookedAt        DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("travel_bookings")
}

// ─────────────────────────────────────────
// ADVERTISEMENT
// ─────────────────────────────────────────

model Advertisement {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String    @db.ObjectId
  business      Business  @relation(fields: [businessId], references: [id])

  title         String
  imageUrl      String
  linkUrl       String?
  placement     String
  width         Int       @default(728)
  height        Int       @default(200)
  status        AdStatus  @default(ACTIVE)
  startDate     DateTime?
  endDate       DateTime?

  impressions   Int @default(0)
  clicks        Int @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("advertisements")
}

// ─────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────

model Category {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  name          String   @unique
  slug          String   @unique
  description   String?
  imageUrl      String?
  icon          String?

  businesses    Business[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("categories")
}

// ─────────────────────────────────────────
// CONTACT INQUIRY
// ─────────────────────────────────────────

model ContactInquiry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  type        String?
  status      String   @default("pending")
  response    String?
  respondedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("contact_inquiries")
}

// ─────────────────────────────────────────
// AUDIT LOG (Admin)
// ─────────────────────────────────────────

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  action      String
  entity      String
  entityId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}
